{
  "name": "my-project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "python scripts/dev-full.py",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "validate:routes": "node scripts/validate-routes.mjs",
    "fix:routes": "node scripts/cleanup-legacy-routes.mjs && node scripts/validate-routes.mjs",
    "predev": "node scripts/cleanup-legacy-routes.mjs && node scripts/validate-routes.mjs",
    "prebuild": "node scripts/cleanup-legacy-routes.mjs && node scripts/validate-routes.mjs",
    "prestart": "node scripts/validate-routes.mjs",
    "dev:web": "next dev",
    "dev:ds": "python -m uvicorn ds_api.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:full": "python scripts/dev-full.py",
    "health:ds": "python -c \"import urllib.request; print(urllib.request.urlopen('http://127.0.0.1:8000/health').read().decode())\"",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:reset": "docker compose down -v --remove-orphans",
    "docker:logs": "docker compose logs -f --tail=200",
    "ingest:dry-run": "python scripts/ingest_elasticsearch.py --dry-run"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@vercel/analytics": "1.6.1",
    "axios": "^1.7.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.3.24",
    "lucide-react": "^1.16.0",
    "maplibre-gl": "^5.24.0",
    "next": "16.2.6",
    "react": "^19",
    "react-dom": "^19",
    "react-icons": "^5.3.0",
    "recharts": "^2.12.7",
    "swr": "^2.2.5",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "postcss": "^8.5",
    "tailwindcss": "^4.2.0",
    "typescript": "5.7.3"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.25"
    }
  }
}
