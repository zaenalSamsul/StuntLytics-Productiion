# Next.js -> Python data-science API
STUNTLYTICS_DS_API_URL=http://127.0.0.1:8000

# Data source: auto | elasticsearch | demo
DS_DATA_MODE=auto
ES_URL=http://localhost:9200
STUNTING_INDEX=stunting-data
NUTRITION_INDEX=jabar-tenaga-gizi
VILLAGE_CHILD_INDEX=jabar-balita-desa
MODEL_SAMPLE_INDEX=stunting-model-sample

# Automatic ingestion
DATA_ARCHIVE=data/Data.zip
INGEST_CHUNK_SIZE=2000
INGEST_INCLUDE_LEGACY_SAMPLE=true
INGEST_RECREATE_ON_CHANGE=true
INGEST_FORCE=false

# Docker ports / memory
ELASTIC_VERSION=8.19.16
ES_PORT=9200
KIBANA_PORT=5601
DS_API_PORT=8000
WEB_PORT=3000
ES_JAVA_OPTS=-Xms1g -Xmx1g

# Optional free-tier narrative layer
# Keep the key server-side; never expose it through NEXT_PUBLIC_*.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_MAX_OUTPUT_TOKENS=4096
GEMINI_TEMPERATURE=0.25
GEMINI_RETRIES=1
